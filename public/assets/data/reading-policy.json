{
  "version": 1,
  "description": "Reading Policy — Wallace 242型の表示ポリシー（唯一の機械可読定義源）。人向け解説は docs/reading-policy.md。scope/priority/phenomenon の変更は必ず本ファイルで行う。",
  "scopes": [
    "verse",
    "phrase",
    "word",
    "multiple"
  ],
  "scope_note": "scope は文字列または配列。'multiple' は ['verse','word'] の別名（正規化はUI側の _policyScopes が行う）。配列形（例: ['verse','word']）は表示面ごとに異なる文章を持つ現象に使う。",
  "priorities": [
    "critical",
    "high",
    "normal",
    "low",
    "hidden"
  ],
  "display_rules": {
    "min_confidence": 0.4,
    "passage_note": {
      "scopes": [
        "verse"
      ],
      "priorities": [
        "critical",
        "high"
      ],
      "note": "scopes は正規化後の原子スコープで照合（'multiple'/配列は verse を含めば一致）。verse_source が projection の現象のみ Projection 走査から表示。discourse は既存 ClauseAnalyzer 経路が正典"
    },
    "phrase_reading": {
      "scopes": [
        "phrase"
      ],
      "priorities": [
        "critical",
        "high",
        "normal"
      ]
    },
    "observation": {
      "scopes": [
        "word"
      ],
      "priorities": [
        "critical",
        "high",
        "normal"
      ],
      "note": "scopes は正規化後の原子スコープで照合（'multiple'/配列は word を含めば一致）。word 側の文章は節文の再利用ではなく『その単語の役割』を語る"
    },
    "hidden_note": "hidden は自然文を一切生成しない（Projection・検索・将来の上級者モードでのみ利用）。low は形態グリッド等の非文章UIが担当"
  },
