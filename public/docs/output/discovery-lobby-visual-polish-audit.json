  "section_1_typography": {
    "items": [
      {
        "id": "T-01",
        "name": "discovery-title font-size 生値",
        "severity": "IMPROVE",
        "selector": ".discovery-title",
        "property": "font-size",
        "current": "1rem (生値)",
        "issue": "var(--text-body-lg) = 1rem が存在するが未参照",
        "recommendation": "font-size: var(--text-body-lg)",
        "effort": "1行",
        "functional_change": false
      },
      {
        "id": "T-02",
        "name": "title と chip が同色（color hierarchy なし）",
        "severity": "IMPROVE",
        "selector": ".discovery-title",
        "property": "color",
        "current": "var(--text-main) = #1d1d1f（chip と同値）",
        "issue": "DS-DISCOVERY-01「テーマ語が主役」を color 階層でも補強できていない。サイズ優位性（20px vs 16px）はあるが、color での分化がない",
        "recommendation": "color: var(--text-sub) = #6e6e73",
        "effort": "1行",
        "functional_change": false
      },
      {
        "id": "T-03",
        "name": "discovery-theme-chip font-family がシステム UI",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip",
        "property": "font-family",
        "current": "inherit（system UI sans-serif）",
        "issue": "unified-input と ex-chip は 'Gentium Plus', serif を使用（フォント読込済）。テーマ語が UI フォントで表示されると「scripture word」ではなく「メニュー項目」に見える",
        "recommendation": "font-family: 'Gentium Plus', serif",
        "effort": "1行",
        "functional_change": false,
        "note": "Gentium Plus は検索入力・例チップで既に使用中。追加読み込みなし"
      },
      {
        "id": "T-04",
        "name": "discovery-title line-height: 1.75",
        "severity": "GOOD",
        "selector": ".discovery-title",
        "property": "line-height",
        "current": "1.75",
        "assessment": "日本語 body text 1.7-1.9 が標準範囲。2行の問いかけ文に適切なブレス"
      },
      {
        "id": "T-05",
        "name": "discovery-theme-chip font-weight 400（暗黙・継承）",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip",
        "property": "font-weight",
        "current": "400（明示定義なし、継承）",
        "issue": "20px/400 の日本語テキストは常時 affordance がない。font-weight: 500 が最も DS-DISCOVERY-02 と競合しない affordance 追加手段",
        "recommendation": "font-weight: 500（または明示的に 400 を記述して intent を文書化）",
        "effort": "1行",
        "requires_design_decision": true
      }
    ]
  },

  "section_2_color": {
    "items": [
      {
        "id": "C-01",
        "name": "hover opacity: 0.55 トークン外",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip:hover",
        "property": "opacity",
        "current": "0.55",
        "issue": "var(--opacity-secondary) = 0.6 が存在するが未参照。視覚差 8% だが token 逸脱",
        "recommendation": "opacity: var(--opacity-secondary)",
        "effort": "1行"
      },
      {
        "id": "C-02",
        "name": "chip background transparent",
        "severity": "GOOD",
        "assessment": "panel 背景 #f5f5f7 にフラットに乗る。DS-DISCOVERY-02 準拠"
      },
      {
        "id": "C-03",
        "name": "アクセント色の非使用",
        "severity": "GOOD",
        "assessment": "accent = #5a6e82 は chip に使用なし。静かなモノクロームの入口として正しい判断"
      }
    ]
  },

  "section_3_spacing": {
    "items": [
      {
        "id": "S-01",
        "name": "padding-top: 48px 生値",
        "severity": "IMPROVE",
        "selector": "#discovery-lobby",
        "property": "padding-top",
        "current": "48px（token スケール外）",
        "issue": "token スケール（4/8/16/24/32px）に 48px なし",
        "recommendation": "calc(var(--space-xl) + var(--space-md)) または --space-2xl トークン追加",
        "effort": "1行（機能変化なし）"
      },
      {
        "id": "S-02",
        "name": "chip と sidebar input の垂直差 13px（目標 30px）",
        "severity": "IMPROVE",
        "selector": "#discovery-lobby",
        "property": "padding-top",
        "current": "chip[0] y=156、input y=143、差=+13px",
        "issue": "ほぼ同水平ライン。「検索補完候補」感が残る",
        "recommendation": "padding-top: 64px → chip[0] y≈172、差≈29px",
        "effort": "1行"
      },
      {
        "id": "S-03",
        "name": ".state-empty gap: 14px トークン外",
        "severity": "IMPROVE",
        "selector": ".state-empty",
        "property": "gap",
        "current": "14px（生値）",
        "recommendation": "gap: var(--space-md) = 16px",
        "effort": "1行",
        "note": "既存 R-01（UX-10-6）と同一"
      },
      {
        "id": "S-04",
        "name": ".discovery-themes gap: var(--space-md)",
        "severity": "GOOD",
        "assessment": "16px チップ間ギャップ。トークン準拠。自然な縦列リズム"
      },
      {
        "id": "S-05",
        "name": "title → themes gap: var(--space-lg)",
        "severity": "GOOD",
        "assessment": "実測 24px（title bottom ≈ 132 → chip[0] ≈ 156）。トークン準拠。適切なブレス"
      }
    ]
  },

  "section_4_interaction": {
    "items": [
      {
        "id": "I-01",
        "name": "transition に ease-out トークン未使用",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip",
        "property": "transition",
        "current": "opacity 0.15s, transform 0.15s（CSS default ease）",
        "issue": "var(--transition-fast) = 0.15s cubic-bezier(0.2,0.8,0.2,1) が存在。hover-off 時の戻りが特に違いが出る",
        "recommendation": "transition: opacity var(--transition-fast), transform var(--transition-fast)",
        "effort": "1行",
        "note": "既存 R-02（UX-10-6）と同一"
      },
      {
        "id": "I-02",
        "name": "hover translateY(-1px) がボタン感",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip:hover",
        "property": "transform",
        "current": "translateY(-1px)",
        "issue": "微小上昇はクリッカブルボタンの慣例表現。DS-DISCOVERY-02「検索候補リストに見えない」設計と緊張関係にある。opacity フェードのみが「静かな応答」として純粋",
        "recommendation": "transform 削除。hover は opacity のみに絞る",
        "effort": "1行（プロパティ削除）"
      },
      {
        "id": "I-03",
        "name": ":active 状態なし",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip:active（未定義）",
        "current": "なし",
        "issue": "モバイルタップ時に視覚フィードバックなし。search 起動まで 100-300ms ラグがあるため特に重要",
        "recommendation": ".discovery-theme-chip:active { opacity: var(--opacity-tertiary); } = 0.3",
        "effort": "3行（新規ルール）"
      },
      {
        "id": "I-04",
        "name": "常時 affordance なし",
        "severity": "IMPROVE",
        "selector": ".discovery-theme-chip（static）",
        "current": "cursor: pointer のみ",
        "issue": "モバイル・タブレットでタップ可能性が視覚的に不明",
        "recommendation": "T-05（font-weight: 500）との統合で対応",
        "effort": "1行（T-05 に統合）",
        "requires_design_decision": true
      }
    ]
  },

  "section_5_search_area": {
    "items": [
      {
        "id": "SA-01",
        "name": "入力 vs chip の視覚的差別化",
        "severity": "GOOD",
        "assessment": "unified-input（border + bg + serif + 0.88rem）vs chip（no border + transparent + 20px）。視覚差十分。水平距離 ≈ 300px でさらに分離"
      },
      {
        "id": "SA-02",
        "name": "chip と input の y 近接",
        "severity": "IMPROVE",
        "note": "S-02 と同一根拠。S-02 を参照"
      }
