{
  "version": "1.0.0",
  "clauses": {
    "clause.purpose": {
      "label_en": "Purpose Clause",
      "label_ja": "目的節",
      "description_ja": "ἵνα / ὅπως で導かれる接続法節。目的または期待される結果を表す。",
      "detection": {
        "strategy": "conjunction_anchor",
        "markers": {
          "lemmas": ["ἵνα", "ὅπως"],
          "pos": ["C"]
        },
        "following_mood": ["subjunctive", "optative"],
        "span": "anchor_to_clause_boundary",
        "max_span": 20
      },
      "confidence_base": 0.90,
      "confidence_modifiers": {
        "following_mood_match":    0.05,
        "following_mood_mismatch": -0.25
      }
    },
    "clause.content": {
      "label_en": "Content Clause",
      "label_ja": "内容節",
      "description_ja": "ὅτι で導かれる節。発言・思考・知覚動詞の補語として内容を表す。前方 4 トークン以内に宣言動詞が必要。",
      "detection": {
        "strategy": "conjunction_anchor",
        "markers": {
          "lemmas": ["ὅτι"],
          "pos": ["C"]
        },
        "context_check": {
          "look": "before",
          "window": 4
        },
        "span": "anchor_to_clause_boundary",
        "max_span": 25
      },
      "confidence_base": 0.75,
      "confidence_modifiers": {
        "context_check_pass": 0.15
      }
    },
    "clause.reason": {
      "label_en": "Reason Clause",
      "label_ja": "理由節",
      "description_ja": "γάρ（後置型）で導かれる理由・根拠節。節頭から anchor の先まで span を取る。",
      "detection": {
        "strategy": "postpositive_anchor",
        "markers": {
          "lemmas": ["γάρ"],
          "pos": ["C"]
        },
        "search_window": 4,
        "span": "clause_head_to_anchor_plus",
        "max_span": 25
      },
      "confidence_base": 0.80,
      "confidence_modifiers": {}
    },
    "clause.condition": {
      "label_en": "Conditional Clause",
      "label_ja": "条件節",
      "description_ja": "εἰ / ἐάν で導かれる条件節（protasis）。帰結節との対応は将来の DiscourseAnalyzer の責務。",
      "detection": {
        "strategy": "conjunction_anchor",
        "markers": {
          "lemmas": ["εἰ", "ἐάν"],
          "pos": ["C"]
        },
        "following_mood": ["indicative", "subjunctive", "optative"],
        "span": "anchor_to_clause_boundary",
        "max_span": 20
      },
      "confidence_base": 0.88,
      "confidence_modifiers": {
        "following_mood_match":    0.07,
        "following_mood_mismatch": -0.20
      }
    },
    "clause.contrast": {
      "label_en": "Contrast Clause",
      "label_ja": "対比節",
      "description_ja": "ἀλλά で導かれる逆接節。前節と対比的な内容を表す。",
      "detection": {
        "strategy": "conjunction_anchor",
        "markers": {
          "lemmas": ["ἀλλά"],
          "pos": ["C"]
        },
        "span": "anchor_to_clause_boundary",
        "max_span": 20
      },
      "confidence_base": 0.85,
      "confidence_modifiers": {}
    }
  }
}
